9.2 分时形态识别代码示例（Python）
python
def analyze_intraday_pattern(stock_code, intraday_df, yesterday_close, ma5):
    """
    intraday_df: DataFrame with columns ['time', 'price', 'avg_price']
    """
    current_price = intraday_df.iloc[-1]['price']
    current_avg = intraday_df.iloc[-1]['avg_price']
    low_price = intraday_df['price'].min()

    # 强势横盘
    if (current_price >= current_avg * 1.001 and
        current_price > yesterday_close and
        (intraday_df['price'] < intraday_df['avg_price'] * 0.995).sum() < 30):
        return 'strong_hold'

    # 回踩支撑
    if (current_price >= current_avg * 1.001 and
        (intraday_df['price'] < intraday_df['avg_price']).any() and
        low_price >= ma5 * 0.98 and  # 允许轻微跌破
        (current_price - low_price) / low_price > 0.01):
        return 'pullback_support'

    return 'normal'
