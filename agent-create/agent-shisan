python
def run_daily_1430():
    # 1. 数据采集
    money_flow_top100 = fetch_money_flow_top100()          # 资金流入前100
    realtime_data = fetch_realtime_quotes(money_flow_top100['code'])
    kline_data = fetch_kline_batch(money_flow_top100['code'])
    board_hot = fetch_board_hot()                          # 板块热度

    # 2. 合并数据
    stocks = merge_data(money_flow_top100, realtime_data, kline_data)

    # 3. 基础条件初筛
    candidates = []
    for s in stocks:
        if not (non_st(s) and listed_days>=60 and 50<=cap<=500):
            continue
        if not has_recent_limit_up(s, days=10):
            continue
        if not (s.price > s.ma5 > s.ma10):
            continue
        if not (3 <= s.turnover <= 25):
            continue
        if not (0.5 <= s.volume_ratio <= 3.0):
            continue
        if not (s.volume > 0.8 * s.vol_ma5):
            continue
        candidates.append(s)

    # 4. 动态评分
    results = []
    for s in candidates:
        score = 0

        # 资金强度
        if s.rank <= 10: score += 20
        elif s.rank <= 30: score += 15
        else: score += 10

        if s.super_large_ratio > 0.3: score += 5
        elif s.super_large_ratio > 0.2: score += 3
        else: score += 1

        if s.continuous_inflow_days >= 3: score += 5
        elif s.continuous_inflow_days == 2: score += 3

        # 板块热度
        if s.board in board_hot['today']: score += 15
        elif s.board in board_hot['last5']: score += 10
        else: score += 5

        # 放量强度
        vol_ratio = s.volume / s.vol_ma5
        if vol_ratio > 2.0: score += 20
        elif vol_ratio > 1.5: score += 15
        elif vol_ratio > 1.2: score += 10
        else: score += 5

        # 分时形态
        pattern = analyze_intraday(s)
        if pattern == 'strong_hold': score += 25
        elif pattern == 'pullback_support': score += 20
        else: score += 10

        # 量价配合
        if 8 <= s.turnover <=14 and 1.0 <= s.volume_ratio <=1.5: score += 10
        elif 5 <= s.turnover <=17 or 0.8 <= s.volume_ratio <=2.0: score += 5

        results.append((s, score))

    # 5. 排序输出
    results.sort(key=lambda x: x[1], reverse=True)
    top10 = results[:10]
    generate_report(top10)
